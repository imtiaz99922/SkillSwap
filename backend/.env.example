MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/<dbname>?retryWrites=true&w=majority

# Node environment (development or production)
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5175

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (Gmail example - use app password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Base URL for email verification links
BASE_URL=http://localhost:5173

# Payment Configuration - SSLCommerz only (Stripe removed)

# For sandbox testing
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=qwerty

# For production, replace with live credentials:
# SSLCOMMERZ_STORE_ID=your_live_store_id
# SSLCOMMERZ_STORE_PASSWORD=your_live_store_password

# Backend and Frontend URLs for SSLCommerz callbacks
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Server Port
PORT=5000
